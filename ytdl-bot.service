[Unit]
Description=MediaFetch Telegram Bot
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/ytdl-bot
EnvironmentFile=/root/ytdl-bot/.env
ExecStart=/root/ytdl-bot/venv/bin/python bot.py
Restart=on-failure
RestartSec=5s
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
