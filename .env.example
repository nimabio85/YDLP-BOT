# ─── Required ─────────────────────────────────────────────────────────────────
# Get this from @BotFather on Telegram
BOT_TOKEN=your_telegram_bot_token_here

# ─── Optional ─────────────────────────────────────────────────────────────────
# Max file size in MB before refusing to upload (Telegram free limit = 50 MB)
MAX_FILE_SIZE_MB=50

# Telegram Bot API server URL. Leave blank for the public Bot API.
# If you run a local Bot API server, you can raise MAX_FILE_SIZE_MB up to 2000.
LOCAL_API_URL=

# Owner/admin Telegram user ID for /stats. Leave 0 to disable owner-only stats.
OWNER_ID=0

# Whitelist specific Telegram user IDs (comma-separated). Leave blank = public.
# Example: ALLOWED_USERS=123456789,987654321
ALLOWED_USERS=

# Directory to store temporary downloads
DOWNLOAD_PATH=/tmp/ytdl-bot

# Directory for JSON history/stats/preferences
DATA_PATH=data

# Optional Netscape-format cookies.txt for sites that need login or bot checks
# Fallback cookie file used when no site-specific file is configured
COOKIES_FILE=

# Optional site-specific cookie files. Put real files in ./cookies/
YOUTUBE_COOKIES_FILE=cookies/youtube.txt
INSTAGRAM_COOKIES_FILE=cookies/instagram.txt
TIKTOK_COOKIES_FILE=cookies/tiktok.txt
SPOTIFY_COOKIES_FILE=cookies/spotify.txt
TWITTER_COOKIES_FILE=cookies/twitter.txt
FACEBOOK_COOKIES_FILE=cookies/facebook.txt

# Queue and safety limits
MAX_CONCURRENT_DOWNLOADS=2
MAX_DURATION_SECONDS=10800
CACHE_TTL_DAYS=60
CACHE_MAX_ENTRIES=1000

# Use aria2c for faster direct-file downloads when aria2c is installed
ENABLE_ARIA2=false
